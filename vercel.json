{
  "installCommand": "echo 'skip'",
  "buildCommand": "echo 'skip'",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/games/:gameId", "destination": "/games/%5BgameId%5D.html" },
    { "source": "/orders/:orderId", "destination": "/orders/%5BorderId%5D.html" },
    { "source": "/games", "destination": "/tabs/games.html" },
    { "source": "/orders", "destination": "/tabs/orders.html" },
    { "source": "/profile", "destination": "/tabs/profile.html" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/_expo/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
